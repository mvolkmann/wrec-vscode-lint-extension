{
  "name": "wrec",
  "displayName": "wrec",
  "description": "Runs 'npx wrec-lint' when a saved file defines a class that extends Wrec.",
  "version": "0.0.3",
  "publisher": "RMarkVolkmann",
  "license": "MIT",
  "icon": "logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/mvolkmann/wrec-lint-on-save-vscode.git"
  },
  "homepage": "https://github.com/mvolkmann/wrec-lint-on-save-vscode#readme",
  "bugs": {
    "url": "https://github.com/mvolkmann/wrec-lint-on-save-vscode/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Linters",
    "Programming Languages"
  ],
  "keywords": [
    "wrec",
    "web-components",
    "lint",
    "typescript",
    "javascript"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:wrec.lintCurrentFile"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "wrec.lintCurrentFile",
        "title": "Wrec: Lint Current File"
      }
    ],
    "configuration": {
      "title": "Wrec Lint On Save",
      "properties": {
        "wrec.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable linting Wrec source files when they are saved."
        },
        "wrec.npxPath": {
          "type": "string",
          "default": "npx",
          "description": "npx executable used to launch the Wrec linter."
        },
        "wrec.showOutput": {
          "type": "string",
          "enum": [
            "never",
            "onIssues",
            "always"
          ],
          "default": "onIssues",
          "description": "Control when the Wrec Lint output channel is shown."
        }
      }
    }
  },
  "scripts": {
    "package": "npx @vscode/vsce package",
    "publish": "npx @vscode/vsce publish"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.2"
  }
}
